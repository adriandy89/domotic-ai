# ─────────────────────────────────────────────────────────────────────────────
# Edge stack per-home configuration.  Copy this file to  ./.env  and fill it in.
#
# Where to get the values:  Dashboard → open the home → Integrations → "Edge (offline)"
# tab.  That tab renders a ready-to-copy snippet with HOME_UNIQUE_ID, CENTRAL_API_URL
# and EDGE_AUTH_TOKEN already filled for THIS home.  (Enable "Offline edge" on the
# home first — Access → edit home → "Offline edge".)
#
# docker compose reads this file automatically for the ${VAR} placeholders in
# docker-compose.yml.  Do NOT commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Home identity — the home unique_id (same value used by zigbee2mqtt & co.).
# WHERE: Integrations → Edge tab (HOME_UNIQUE_ID line) or any protocol tab (the MQTT user).
HOME_UNIQUE_ID=1234-fake-id-long-string

# Central backend base URL the edge calls to pull rules + upload execution logs.
# It is the dashboard's own API origin WITHOUT the /api/v1 suffix.
# WHERE: Integrations → Edge tab (CENTRAL_API_URL line). e.g. https://api.your-domotic.com
CENTRAL_API_URL=https://api.your-domotic-server.com

# Per-home auth token: verifies the signed rules bundle AND authenticates the edge
# against the central API.  Unique per home (derived from the server master secret).
# WHERE: Integrations → Edge tab (EDGE_AUTH_TOKEN line).  Reveal + copy it.
EDGE_AUTH_TOKEN=paste-from-dashboard-edge-tab

# ── Local mosquitto credentials for the edge-rules-engine client ──────────────
# These are LOCAL-only and chosen by YOU (not from the dashboard). After setting
# them, create the mosquitto password file so the broker accepts this user:
#   docker run --rm -it -v "$PWD/mosquitto:/m" eclipse-mosquitto:2-openssl \
#     mosquitto_passwd -c /m/passwords "$EDGE_MQTT_USER"
EDGE_MQTT_USER=edge-rules
EDGE_MQTT_PASS=choose-a-strong-password

# Timezone for local schedules / execution windows (host clock via NTP).
TZ=Europe/Madrid

# How often (seconds) the local care watchdog scans for STALE/INACTIVE devices.
WATCHDOG_INTERVAL_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# Also edit  mosquitto/mosquitto.conf  (NOT read from this .env) — bridge section:
#   address         <TBMQ host>:<port>   ← Integrations → any tab (broker host:port)
#   remote_username <HOME_UNIQUE_ID>     ← same as above
#   remote_password <home MQTT password> ← Integrations → any protocol tab (password)
# ─────────────────────────────────────────────────────────────────────────────
