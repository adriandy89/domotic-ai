# Base URL of the Domotic-AI backend API, including the /api/v1 prefix.
# Used by the dashboard (axios + SSE) and to derive the edge CENTRAL_API_URL shown
# in home → Integrations → Edge (the same origin without /api/v1).
# WHERE TO SET: web/.env at build time (Vite inlines VITE_* at build).
# Local dev: http://localhost:3017/api/v1 · Prod: https://api.your-domotic.com/api/v1
VITE_API_URL=http://localhost:3017/api/v1
